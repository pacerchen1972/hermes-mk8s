---
# Sealed Secret: Encrypted secret for production deployment
#
# Created by sealing secret.yaml using kubeseal:
#   kubeseal -f k8s/secret.yaml -w k8s/sealed-secret.yaml
#
# Only the cluster with the matching sealing key can decrypt this.
# Safe to commit to git.
#
# To use this template:
#   1. Create secret.yaml with real values (see secret.yaml.example)
#   2. Install sealed-secrets operator: kubectl apply -f https://github.com/bitnami-labs/sealed-secrets/releases/download/v0.27.0/controller.yaml
#   3. Seal: kubeseal -f secret.yaml -w sealed-secret.yaml
#   4. Apply: kubectl apply -f sealed-secret.yaml
#   5. Delete secret.yaml (it's no longer needed)

apiVersion: bitnami.com/v1alpha1
kind: SealedSecret
metadata:
  name: hermes-secrets
  namespace: hermes
  labels:
    app: hermes
spec:
  encryptedData:
    # These are example encrypted values - replace with your actual sealed values
    HERMES_API_KEY: AgBvj9x8KL+... (encrypted content)
    HERMES_MODEL_BASE_URL: AgEt2F1pK9+... (encrypted content)
  template:
    metadata:
      name: hermes-secrets
      namespace: hermes
    type: Opaque
