---
# Secret: Sensitive Hermes configuration (API keys, tokens, credentials)
#
# DO NOT commit this file with real values. Use sealed-secret.yaml in production.
# To create this secret from the example:
#
#   1. Copy this file to secret.yaml
#   2. Fill in the base64-encoded values:
#      echo -n "your-api-key" | base64
#   3. Apply: kubectl apply -f k8s/secret.yaml
#
# For production, use kubeseal:
#   1. Install sealed-secrets operator on cluster
#   2. Create secret.yaml with real values
#   3. Seal it: kubeseal -f secret.yaml -w sealed-secret.yaml
#   4. Commit sealed-secret.yaml, delete secret.yaml

apiVersion: v1
kind: Secret
metadata:
  name: hermes-secrets
  namespace: hermes
  labels:
    app: hermes
type: Opaque
data:
  # IONOS AI Model Hub API token (base64-encoded)
  # Get this from: https://cloud.ionos.co.uk/ai-model-hub
  HERMES_API_KEY: "aW9ub3MtYWktbW9kZWwtaHViLWFwaS1rZXktaGVyZQ=="

  # Model API endpoint URL (base64-encoded)
  # Example: https://api.models.ionos.cloud/v1
  HERMES_MODEL_BASE_URL: "aHR0cHM6Ly9hcGkubW9kZWxzLmlvbm9zLmNsb3VkL3Yx"

  # Alternative: Use OpenRouter as model provider
  # HERMES_API_KEY: "your-openrouter-api-key"
  # HERMES_MODEL_BASE_URL: "https://openrouter.ai/api/v1"

  # Optional: Telegram bot token (if using Telegram integration)
  # Get from @BotFather on Telegram
  # TELEGRAM_BOT_TOKEN: "dGVsZWdyYW0tYm90LXRva2VuLWhlcmU="
